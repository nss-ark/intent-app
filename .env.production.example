# Intent Production Environment Variables
# Copy to .env.production.local and fill in real values

# Database (Postgres)
DATABASE_URL="postgresql://user:password@host:5432/intent?schema=public"

# Auth
NEXTAUTH_SECRET="generate-a-real-secret-here-openssl-rand-base64-32"
NEXTAUTH_URL="https://isb.intent.community"

# Demo mode OFF in production
NEXT_PUBLIC_DEMO_MODE="false"

# Email (Resend)
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""

# Object Storage (Cloudflare R2 or AWS S3)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# Error tracking
SENTRY_DSN=""

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
