# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET=""           # Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Demo mode - set to "true" for local dev browsing without auth
NEXT_PUBLIC_DEMO_MODE="true"

# Email (Gmail SMTP)
EMAIL_PROVIDER="gmail"
GMAIL_USER=""                # your-app@gmail.com
GMAIL_APP_PASSWORD=""        # 16-char app password from Google Account > Security > App Passwords

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# GitHub token for feature request issues (needs repo scope)
GITHUB_TOKEN=""
